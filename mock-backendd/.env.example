# ============================================================
# Configuration du Mock Backend
# Copiez ce fichier en .env et modifiez les valeurs
# ============================================================

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ordonnance_db
DB_USER=ordonnance_user
DB_PASSWORD=ordonnance_pass

# JWT - Clé secrète (changez en production !)
JWT_SECRET=ordonnance_jwt_secret_key_changez_moi_en_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=ordonnance_refresh_secret_key_changez_moi
JWT_REFRESH_EXPIRES_IN=7d

# Frontend autorisé (CORS)
FRONTEND_URL=http://localhost:3000

# MinIO (stockage fichiers)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ordonnances
